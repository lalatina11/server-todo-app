{
	"name": "server-todo-app",
	"version": "1.0.50",
	"type": "module",
	"scripts": {
		"dev": "bun --watch src/index.ts",
		"start": "bun run src/index.ts",
		"format": "biome format --write",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"auth:generate": "bun x auth@latest generate --output ./src/db/schema/auth-schema.ts -y"
	},
	"dependencies": {
		"@hono/swagger-ui": "^0.5.3",
		"@hono/zod-validator": "^0.7.6",
		"@neondatabase/serverless": "^1.0.2",
		"better-auth": "^1.5.2",
		"dotenv": "^17.3.1",
		"drizzle-orm": "^0.45.1",
		"hono": "^4.11.7",
		"pg": "^8.18.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.13",
		"@types/bun": "latest",
		"@types/pg": "^8.16.0",
		"drizzle-kit": "^0.31.8",
		"esbuild": "^0.27.3",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3"
	},
	"module": "src/index.js"
}
